<style>
  .riccio-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 56rem;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .riccio-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .riccio-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Hermès-style: gradient only at bottom for text legibility */
  .riccio-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 8, 6, 0.72) 0%,
      rgba(10, 8, 6, 0.2) 35%,
      transparent 65%
    );
    z-index: 1;
  }

  /* Content: bottom-left like Hermès */
  .riccio-hero__content {
    position: relative;
    z-index: 2;
    padding: 5.6rem 6rem;
    max-width: 72rem;
    animation: hero-fade-up 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: 0.2s;
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(1.6rem); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Italic serif title — Hermès style */
  .riccio-hero__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 6.4rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.08;
    color: #ffffff;
    margin: 0 0 1.6rem;
    letter-spacing: 0.01em;
  }

  .riccio-hero__description {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.35rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.82);
    margin: 0 0 2.8rem;
    max-width: 52rem;
    letter-spacing: 0.04em;
  }

  /* Hermès CTA: uppercase underline, no box */
  .riccio-hero__cta {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.7);
    padding-bottom: 0.3rem;
    transition: border-color 0.2s ease;
  }

  .riccio-hero__cta:hover {
    border-color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .riccio-hero__content {
      padding: 4rem 2.4rem;
    }
    .riccio-hero__title {
      font-size: 4.4rem;
    }
    .riccio-hero__description {
      font-size: 1.25rem;
    }
  }
</style>

<div class="riccio-hero">
  <div class="riccio-hero__media">
    <img
      src="{{ 'image riccio/image0 (1).jpeg' | asset_url }}"
      alt="RICCIO MAISON — L'Élégance au Quotidien"
      width="2000"
      height="2667"
      loading="eager"
      fetchpriority="high"
    >
  </div>

  <div class="riccio-hero__overlay"></div>

  <div class="riccio-hero__content">
    <h1 class="riccio-hero__title">L'élégance<br>au quotidien</h1>
    <p class="riccio-hero__description">
      Des objets en cuir d'exception, façonnés pour sublimer chaque instant de votre intérieur.
    </p>
    <a href="/collections/stressa" class="riccio-hero__cta">Découvrir la collection</a>
  </div>
</div>

{% schema %}
{
  "name": "Riccio — Hero",
  "tag": "section",
  "class": "section-riccio-hero",
  "settings": [],
  "presets": [{ "name": "Riccio — Hero" }]
}
{% endschema %}
